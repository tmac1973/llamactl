# llamactl environment configuration
#
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# If you use ./setup.sh install, the .env file is generated automatically.
# Edit .env directly to change settings without re-running setup.

# ─── Port configuration ──────────────────────────────────────────────────────
# Host ports for the llamactl services. The container listens internally on
# 3000 (UI) and 8080 (inference) — these settings control which host ports
# map to them. Change these if the defaults conflict with other services.

LLAMACTL_PORT=3000
LLAMACTL_INFERENCE_PORT=8080

# ─── Model storage ───────────────────────────────────────────────────────────
# Mount a host directory for model storage so models survive container/volume
# removal. Leave commented out to store models in the Docker volume.
# The directory will be created if it doesn't exist.
#LLAMACTL_MODELS_DIR=/home/user/llm-models

# ─── AMD ROCm settings (only needed for AMD GPUs) ────────────────────────────
# These are auto-detected by setup.sh. Only set manually if auto-detection
# gets it wrong or you're not using setup.sh.

# HSA_OVERRIDE_GFX_VERSION — Override the GPU architecture reported to ROCm.
# Only needed for GPUs not natively supported by ROCm (e.g. RDNA 1, Vega).
# Examples: 10.1.0 (RDNA 1), 9.0.0 (Vega)
# Leave commented out for RDNA 2/3/4 GPUs.
#HSA_OVERRIDE_GFX_VERSION=

# Host group IDs for GPU device access inside the container.
# Find yours with: getent group video | cut -d: -f3
#                  getent group render | cut -d: -f3
#HOST_VIDEO_GID=
#HOST_RENDER_GID=
